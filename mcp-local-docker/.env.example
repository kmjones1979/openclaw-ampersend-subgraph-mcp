# === Required ===

# The Graph Gateway API key (get from https://thegraph.com/studio)
GATEWAY_API_KEY=

# x402 payment recipient address (your wallet on Base mainnet)
PAY_TO_ADDRESS=

# === Coinbase CDP (required for x402 payment facilitation) ===
# Create an app at https://portal.cdp.coinbase.com
# Generate an Ed25519 API key pair for the app

CDP_APP_ID=
CDP_SECRET=

# === Optional (defaults shown) ===

# x402 network (CAIP-2 format)
# X402_NETWORK=eip155:8453

# CDP facilitator URL
# FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Price per MCP tool call in USD (USDC)
# PRICE_PER_CALL=0.01

# Ampersend (optional, for additional payment authorization)
# AMPERSEND_API_KEY=
# AMPERSEND_API_URL=https://api.ampersend.ai
